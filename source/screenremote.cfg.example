# screenremote configuration
# Copy this file to /korg/rw/screenremote/screenremote.cfg on the Kronos and edit as needed.
# The /korg/rw/screenremote/ directory is created automatically by the daemon on first run.
# Changes take effect the next time screenremote starts (reboot, or rmmod/insmod).
#
# Lines beginning with # are comments and are ignored.
# Recognised keys: stream_port, ctrl_port, screensaver_timeout
#
# Default values are shown below (commented out).
# Uncomment and change a line to override the default.

#stream_port=7373
#ctrl_port=7374

# screensaver_timeout: seconds of no fb1 change before VGA output is blanked.
# Set to 0 to disable. Default is 300 (5 minutes).
# Only affects fb0 (VGA mirror) — the Kronos display (fb1) is never touched.
#screensaver_timeout=300
